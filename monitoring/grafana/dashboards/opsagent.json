{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "🔥 OpsAgent — Production Dashboard",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "### Real-time monitoring for alerts, RCA workflows, MCP server health, and queue depth"
      }
    },
    {
      "title": "Alerts Received",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 2 },
      "targets": [
        {
          "expr": "opsagent_alerts_received_total",
          "legendFormat": "Total Alerts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "title": "RCA Completed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 2 },
      "targets": [
        {
          "expr": "opsagent_rca_completed_total",
          "legendFormat": "Completed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "title": "RCA Failed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 2 },
      "targets": [
        {
          "expr": "opsagent_rca_failed_total",
          "legendFormat": "Failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "title": "RabbitMQ Queue Depth",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 2 },
      "targets": [
        {
          "expr": "opsagent_queue_depth",
          "legendFormat": "Pending Alerts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "title": "Workflow Duration (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "rate(opsagent_workflow_duration_seconds_sum[5m]) / rate(opsagent_workflow_duration_seconds_count[5m])",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme"
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "HTTP Request Rate (by endpoint)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{method}} {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "HTTP Response Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme"
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "MCP Server Health",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "up{job=~\"k8s-mcp|prom-mcp|github-mcp|jira-mcp|auth\"}",
          "legendFormat": "{{job}}",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "1": { "text": "✅ UP", "color": "green" } } },
                  { "type": "value", "options": { "0": { "text": "❌ DOWN", "color": "red" } } }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "title": "JWT Tokens Issued (rate/5m)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "rate(opsagent_jwt_tokens_issued_total[5m])",
          "legendFormat": "{{scope}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Jira Tickets Created",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "opsagent_jira_tickets_created_total",
          "legendFormat": "Tickets"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "title": "Success Rate (%)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 22 },
      "targets": [
        {
          "expr": "opsagent_rca_completed_total / (opsagent_rca_completed_total + opsagent_rca_failed_total) * 100",
          "legendFormat": "Success %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["opsagent", "sre", "production"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "OpsAgent — Production Dashboard",
  "uid": "opsagent-prod",
  "version": 1
}
 