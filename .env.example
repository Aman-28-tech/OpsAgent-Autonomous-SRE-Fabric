
# -- Groq (required for LLM synthesis — FREE!) ---------------------------
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-key-here

# -- LLM model (Groq models — all free) ----------------------------------
# Options: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
LLM_MODEL=llama-3.3-70b-versatile

# -- Langfuse (optional — for observability dashboard) -------------------
LANGFUSE_PUBLIC_KEY=pk-your-key-here
LANGFUSE_SECRET_KEY=sk-your-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# -- Quality threshold for CI/CD gate -----------------------------------
RCA_QUALITY_THRESHOLD=0.90

# -- JWT Auth (shared secret between auth service and MCP servers) -------
JWT_SECRET=opsagent-dev-secret-change-in-prod
JWT_TTL_SECONDS=300

# -- K8s Live Mode (set to "live" + provide kubeconfig to use real K8s) --
K8S_SANDBOX_MODE=mock
KUBECONFIG_PATH=~/.kube/config

# -- RabbitMQ (alert queue) ----------------------------------------------
USE_QUEUE=true
# RABBITMQ_URL is set automatically in docker-compose

# -- Jira (for auto-ticketing MCP) ---------------------------------------
JIRA_BASE_URL=https://company.atlassian.net
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=OPS

# -- GitHub (for live GitHub MCP) -----------------------------------------
GITHUB_TOKEN=ghp_your-github-pat-here

# -- Grafana (auto-provisioned, no config needed) ------------------------
# Dashboard: http://localhost:3000  (admin / opsagent)
# Prometheus: http://localhost:9090
# RabbitMQ UI: http://localhost:15672  (guest / guest)
